---
import Cursor from "@/components/Cursor.astro";
import Logo from "@/components/Logo.astro";
---

<footer
  class="w-full pt-24 md:pt-32 pb-3 bg-dark flex justify-center items-center"
>
  <div class="footer-wrapper w-full px-fluid-md space-y-16">
    <div class="w-full grid grid-cols-1 md:grid-cols-12 gap-fluid-sm">
      <div
        class="bg-brand col-span-full md:col-span-7 rounded-md p-6 h-84 flex flex-col justify-between"
      >
        <div>
          <p class="text-dark">Have a project in mind?</p>
          <h2 class="text-dark text-fluid-2xl">Let's chat, no catch</h2>
        </div>
        <div>
          <a
            href="mailto:info@nediakstudio.com"
            class="footer-cta-link text-dark font-semibold text-fluid-4xl after:bg-dark relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
            >Send Message</a
          >
        </div>
      </div>
      <div
        class="bg-light col-span-full md:col-span-5 rounded-md p-6 h-84 flex flex-col justify-between"
      >
        <div>
          <p class="text-dark">Just want to say hi?</p>
          <h2 class="text-fluid-2xl">For questions or collaboration</h2>
        </div>
        <div>
          <a
            href="mailto:hello@nediakstudio.com"
            class="footer-cta-link text-dark font-semibold text-fluid-4xl after:bg-dark relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
            >Say Hello</a
          >
        </div>
      </div>
    </div>
    <div class="footer-links-wrappper grid grid-cols-1 md:grid-cols-12 gap-6">
      <div class="cols-span-full md:col-start-1 md:col-end-2">
        <div>
          <p class="text-light text-fluid-xs">Explore</p>
        </div>
        <div class="flex flex-col">
          <a
            href="/portfolio"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Portfolio
          </a>
          <a
            href="/studio"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Studio
          </a>
          <a
            href="/process"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Process
          </a>
          <a
            href="/contact"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Contact
          </a>
        </div>
      </div>
      <div class="cols-span-full md:col-start-3 md:col-end-4">
        <div>
          <p class="text-light text-fluid-xs">Socials</p>
        </div>
        <div class="flex flex-col">
          <a
            href=""
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            X(Twitter)
          </a>
          <a
            href=""
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Instagram
          </a>
          <a
            href=""
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link text-light text-fluid-lg font-neueMed hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            LinkedIn
          </a>
        </div>
      </div>
      <div class="cols-span-full md:col-start-10 md:col-end-13 space-y-3">
        <div class="flex flex-col items-start md:items-end">
          <p class="text-light text-fluid-xs text-left md:text-right">Email</p>
          <a
            href="mailto:info@nediakstudio.com"
            class="footer-link text-light text-fluid-lg font-neueMed text-left md:text-right hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
            >info@nediakstudio.com</a
          >
        </div>
        <div class="flex flex-col items-start md:items-end">
          <p class="text-light text-fluid-xs text-left md:text-right">Phone</p>

          <a
            href="tel:+1-305-484-1906"
            class="footer-link text-light text-fluid-lg font-neueMed text-left md:text-right hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
            >305-484-1906</a
          >
        </div>
      </div>
    </div>
    <div class="details-wrapper flex flex-col">
      <div class="border-b border-light pb-fluid-sm">
        <Logo class="text-light" />
      </div>
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-center pt-fluid-sm"
      >
        <div>
          <p class="text-light text-fluid-sm">
            Nediak Studio 2026, All rights reserved
          </p>
        </div>
        <div>
          <a
            href="/privacy-policy"
            class="privacy text-light text-fluid-sm font-semibold hover:text-brand after:bg-brand relative inline-block w-fit transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-[calc(100%-1px)] after:origin-right after:scale-x-0 after:transition-transform after:duration-400 after:ease-in after:content-[''] hover:after:origin-left hover:after:scale-x-100"
          >
            Privacy Policy
          </a>
        </div>
        <div>
          <p class="text-light text-fluid-sm">NJ, USA</p>
        </div>
      </div>
      <Cursor />
    </div>
  </div>
</footer>
