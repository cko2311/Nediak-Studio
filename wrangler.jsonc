{
  "name": "nediak-studio",
  "compatibility_date": "2026-04-03", // Update to the day you deploy
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
